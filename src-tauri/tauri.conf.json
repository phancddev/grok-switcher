{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Switcher",
  "version": "0.1.0",
  "identifier": "com.phancd.grok-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Grok Switcher",
        "width": 920,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://cli-chat-proxy.grok.com https://auth.x.ai; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "appimage", "deb"],
    "category": "Utility",
    "shortDescription": "Multi-account switcher for Grok Build",
    "longDescription": "Manage multiple Grok Build accounts, switch credentials, and check quota from a simple desktop app.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "Grok Switcher"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
